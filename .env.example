# Sponsor Integrations
TAVILY_API_KEY="tvly-..."

# ClickHouse (Tracing & Metrics)
CLICKHOUSE_URL="https://..."
CLICKHOUSE_KEYID=""
CLICKHOUSE_KEYSECRET=""

# LLM / Tessl (Orchestration & Node Generation)
GOOGLE_GENERATIVE_AI_API_KEY="..."

# Cursor Agent SDK (Stage 2 extractor build loop). When unset, the build loop
# falls back to the Gemini generateCode path so the demo never hard-fails.
CURSOR_API_KEY="cursor_..."

# App Settings
NODE_ENV="development"
# Quick discover stops probing when top suggestion confidence reaches this (0–1)
DISCOVERY_CONFIDENCE_THRESHOLD="0.55"
